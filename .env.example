# ============================================================
# PARSPEL — Ortam Değişkenleri Şablonu
# ============================================================
# Bu dosyayı kopyalayarak .env adıyla kaydedin:
#   cp .env.example .env
# Gerçek değerleri Firebase Console ve Google AI Studio'dan alın.
# .env dosyasını asla git'e commit etmeyin!
# ============================================================

# ── Firebase Yapılandırması ──────────────────────────────────
# Firebase Console → Proje Ayarları → Genel → Web uygulaması
VITE_FIREBASE_API_KEY=your_firebase_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
VITE_FIREBASE_APP_ID=your_firebase_app_id

# Firebase Firestore sync için doküman yolu (opsiyonel)
VITE_FIREBASE_DOC_PATH=sync/main

# ── Google Gemini AI ─────────────────────────────────────────
# Google AI Studio → https://aistudio.google.com/app/apikey
VITE_GEMINI_API_KEY=your_gemini_api_key_here

# ── Notlar ───────────────────────────────────────────────────
# google-services.json dosyası için:
#   Firebase Console → Proje Ayarları → Genel → Android uygulaması
#   İndirilen dosyayı android/app/google-services.json konumuna koyun.
#   Bu dosya .gitignore'da tanımlıdır — git'e commit edilmez.
